    public HomePanel(Employee employee) {
        this.employee = employee;
        loadVideoFromResource();
        this.createUIComponents();
    }

    private void loadVideoFromResource(){
        try {
            // Try to load product.mp4 first
            java.io.File videoFile = new java.io.File("product.mp4");
            if (videoFile.exists()) {
                // Create a thumbnail from the video by trying to load it
                // For now, use a placeholder image with a play button overlay
                try {
                    // Try to create a frame from video - this is a simplified approach
                    videoIcon = new ImageIcon(getClass().getResource("/resources/images/ship_repair_anim_01.gif"));
                } catch (Exception e) {
                    videoIcon = null;
                }
                System.out.println("✓ Product video found at: " + videoFile.getAbsolutePath());
            } else {
                // Load animated GIF as fallback
                videoIcon = new ImageIcon(getClass().getResource("/resources/images/ship_repair_anim_01.gif"));
            }
            
            if (videoIcon != null) {
                int originalWidth = videoIcon.getIconWidth();
                int originalHeight = videoIcon.getIconHeight();
                iH = (int) (((double) iW / originalWidth) * originalHeight);
            }
        } catch (Exception e) {
            System.out.println("Error loading video animation!");
            System.out.println(e.getLocalizedMessage());
        }
    }

    private void createUIComponents() {

        this.setLayout(null);
        this.setBackground(new Color(245, 248, 250));
        
        String name = "Welcome " + employee.getTitle() + " " + employee.getFirstName() + " " + employee.getLastName() + "!";

        welcomeLabel = CS.paintLabels(this, "", name, "#1abc9c", fgColor, 0, true);
        welcomeLabel.setFont(new Font("Segoe UI", Font.BOLD, 22));
        this.add(welcomeLabel);
        welcomeLabel.setBounds(30, 20, 900, 35);

        // Create video display panel with enhanced styling
        JPanel videoContainerPanel = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(java.awt.RenderingHints.KEY_ANTIALIASING, 
                                    java.awt.RenderingHints.VALUE_ANTIALIAS_ON);
                
                // Draw shadow
                g2d.setColor(new Color(0, 0, 0, 25));
                g2d.fillRoundRect(3, 3, getWidth()-6, getHeight()-6, 15, 15);
                
                // Draw white background
                g2d.setColor(Color.WHITE);
                g2d.fillRoundRect(0, 0, getWidth()-3, getHeight()-3, 15, 15);
                
                // Draw border with gradient effect
                g2d.setColor(new Color(26, 188, 156));
                g2d.setStroke(new BasicStroke(3));
                g2d.drawRoundRect(0, 0, getWidth()-3, getHeight()-3, 15, 15);
            }
        };
        videoContainerPanel.setLayout(null);
        videoContainerPanel.setBounds(30, 70, 360, 290);
        this.add(videoContainerPanel);

        // Video display label
        videoDisplayLabel = new JLabel();
